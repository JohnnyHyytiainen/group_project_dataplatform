.ruff_cache/
# Mypy cache (type checking history)
.mypy_cache/
.dmypy.json
# Pytest cache
.pytest_cache/
# --- Python Cache (Bytecode) ---
__pycache__/
*.py[cod]
*$py.class
# Coverage reports (när jag kör pytest --cov)
.coverage
htmlcov/
coverage.xml

